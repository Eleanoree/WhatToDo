<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/taskCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/taskDoneCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:buttonTint="@color/brand_teal"
                android:contentDescription="@string/summary_completed" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/taskTitleText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="回覆客戶訊息" />

                    <TextView
                        android:id="@+id/taskCompletedBadgeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_priority_low"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="@string/task_completed_badge"
                        android:textColor="@color/priority_low_text"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/taskNoteText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="3"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="先整理重點再發送，避免漏掉需求。" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/taskDueDateText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        tools:text="到期：2026/04/12" />

                    <TextView
                        android:id="@+id/taskPriorityText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textColor="@color/priority_low_text"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="低" />

                    <TextView
                        android:id="@+id/taskCategoryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textColor="@color/category_chip_text"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="分類：工作" />
                </LinearLayout>

                <TextView
                    android:id="@+id/taskTagsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/tag_chip_text"
                    android:textSize="11sp"
                    tools:text="標籤：#重要  #交期" />

                <TextView
                    android:id="@+id/taskRepeatText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_repeat_pill"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/repeat_chip_text"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:text="重複：每週 週六" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/taskSparkleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="14dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/taskSparkleLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task_star_left"
                android:textColor="@color/brand_red"
                android:textSize="16sp"
                android:alpha="0" />

            <TextView
                android:id="@+id/taskSparkleCenter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/task_star_center"
                android:textColor="@color/brand_powder"
                android:textSize="18sp"
                android:alpha="0" />

            <TextView
                android:id="@+id/taskSparkleRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/task_star_right"
                android:textColor="@color/brand_sky"
                android:textSize="16sp"
                android:alpha="0" />
        </LinearLayout>
    </FrameLayout>

</com.google.android.material.card.MaterialCardView>

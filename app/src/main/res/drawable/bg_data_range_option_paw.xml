<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFDF8F3" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#FFE7D9D2" />
        </shape>
    </item>

    <item
        android:gravity="end|center_vertical"
        android:right="10dp">
        <shape android:shape="oval">
            <size
                android:width="24dp"
                android:height="24dp" />
            <solid android:color="#1FBF8A94" />
        </shape>
    </item>

    <item
        android:gravity="end|top"
        android:top="14dp"
        android:right="18dp">
        <shape android:shape="oval">
            <size
                android:width="10dp"
                android:height="10dp" />
            <solid android:color="#1FBF8A94" />
        </shape>
    </item>

    <item
        android:gravity="end|top"
        android:top="8dp"
        android:right="30dp">
        <shape android:shape="oval">
            <size
                android:width="8dp"
                android:height="8dp" />
            <solid android:color="#1FBF8A94" />
        </shape>
    </item>

    <item
        android:gravity="end|top"
        android:top="12dp"
        android:right="40dp">
        <shape android:shape="oval">
            <size
                android:width="8dp"
                android:height="8dp" />
            <solid android:color="#1FBF8A94" />
        </shape>
    </item>

    <item
        android:gravity="end|top"
        android:top="18dp"
        android:right="26dp">
        <shape android:shape="oval">
            <size
                android:width="8dp"
                android:height="8dp" />
            <solid android:color="#1FBF8A94" />
        </shape>
    </item>
</layer-list>
